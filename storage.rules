rules_version = '2';

// Craft rules for Firebase Storage
// See https://firebase.google.com/docs/storage/security

service firebase.storage {
  match /b/{bucket}/o {
    match /id-cards/{userId}/{allPaths=**} {
      // Temporarily allowing all access to debug permission issues
      allow read, write: if true;
    }
    
    // Default: Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
